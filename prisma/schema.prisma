generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  WORKER
  CLIENT
  ADMIN
}

enum ApplicationStatus {
  PENDING
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

enum VerificationBadge {
  KYC_VERIFIED
  SKILL_VERIFIED
  SQUAD_VOUCHED
}

enum GeofenceRing {
  CORE
  TRANSIT
  CLOUD
}

enum ConnectionStatus {
  PENDING_CONTACT
  IN_PROGRESS
  COMPLETED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  DELIVERED
  APPROVED
}

enum SquadRole {
  LEAD
  MEMBER
  CONTRIBUTOR
}

enum StandbyStatus {
  AVAILABLE
  BUSY
  OFFLINE
}

enum JobApplicationStatus {
  PENDING
  SHORTLISTED
  REJECTED
  HIRED
}

enum ServiceTierName {
  BASIC
  STANDARD
  PREMIUM
}

enum ServiceOrderStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  DELIVERED
  COMPLETED
  DECLINED
  CANCELLED
}

enum CollarType {
  WHITE
  GREY
  BLUE
}

enum RateType {
  FIXED
  HOURLY
}

enum ExperienceLevel {
  ENTRY
  INTERMEDIATE
  EXPERT
}

enum AvailabilityStatus {
  AVAILABLE_NOW
  OPEN_TO_OFFERS
  NOT_AVAILABLE
}

enum WeeklyAvailability {
  AS_NEEDED
  LESS_THAN_30
  THIRTY_PLUS
  FULL_TIME
}

enum LanguageProficiency {
  BASIC
  CONVERSATIONAL
  FLUENT
  NATIVE_OR_BILINGUAL
}

enum JobWeeklyHours {
  LESS_THAN_30
  THIRTY_PLUS
  TBD
}

enum ProjectDuration {
  LESS_THAN_1_MONTH
  ONE_TO_3_MONTHS
  THREE_TO_6_MONTHS
  MORE_THAN_6_MONTHS
}

enum ProjectType {
  ONE_TIME
  ONGOING
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  password     String
  role            Role     @default(WORKER)
  phone           String?
  country         String?
  paymentVerified Boolean  @default(false)
  phoneVerified   Boolean  @default(false)
  isSuspended     Boolean  @default(false)
  referralCode    String?  @unique @default(cuid())
  referredById    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workerProfile         WorkerProfile?
  jobRequirements       JobRequirement[]
  introducedConnections MatchmakingConnection[] @relation("IntroducedBy")
  squadMemberships      SquadMembership[]
  sentMessages          Message[]               @relation("SentMessages")
  serviceOrders         ServiceOrder[]          @relation("ClientOrders")
  referredBy            User?                   @relation("Referrals", fields: [referredById], references: [id])
  referrals             User[]                  @relation("Referrals")

  @@index([email])
  @@index([role])
  @@index([referredById])
}

model WorkerProfile {
  id                 String              @id @default(cuid())
  userId             String              @unique
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedinUrl        String
  portfolioUrls      String[]
  experienceText     String?
  skills             String[]
  bio                String?
  avatarUrl          String?
  title              String?
  hourlyRate         Int?
  location           String?
  timezone           String?
  availabilityStatus AvailabilityStatus  @default(OPEN_TO_OFFERS)
  weeklyAvailability WeeklyAvailability   @default(AS_NEEDED)
  openToContractHire Boolean             @default(false)
  responseTime       String?
  idVerified         Boolean             @default(false)
  phoneVerified      Boolean             @default(false)
  isVerified         Boolean             @default(false)
  status             ApplicationStatus   @default(PENDING)
  verificationNotes  String?
  verificationBadges VerificationBadge[]
  sandboxScore       Int?
  candidateCode      String              @unique @default(cuid())
  isOnStandby        Boolean             @default(false)
  standbyStatus      StandbyStatus       @default(OFFLINE)
  fillRate           Float               @default(100)
  hoursTrained       Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  connections        MatchmakingConnection[]
  sandboxSubmissions SandboxSubmission[]
  standbyAssignments StandbyAssignment[]
  reviews            Review[]
  jobApplications    JobApplication[]
  workSubmissions    WorkSubmission[]
  subJobsPosted      SubJob[]            @relation("PostedSubJobs")
  subJobApplications SubJobApplication[]
  servicePackages    ServicePackage[]
  serviceOrders      ServiceOrder[]      @relation("WorkerOrders")
  portfolioProjects  PortfolioProject[]
  employmentHistory  EmploymentHistory[]
  education          Education[]
  certifications     Certification[]
  languages          WorkerLanguage[]

  @@index([isVerified])
  @@index([status])
  @@index([isOnStandby])
}

model SandboxChallenge {
  id            String   @id @default(cuid())
  title         String
  description   String
  skillCategory String
  questions     Json
  timeLimit     Int      @default(30)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  submissions SandboxSubmission[]
}

model SandboxSubmission {
  id          String           @id @default(cuid())
  workerId    String
  challengeId String
  worker      WorkerProfile    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  challenge   SandboxChallenge @relation(fields: [challengeId], references: [id])
  answers     Json
  score       Int?
  gradedAt    DateTime?
  createdAt   DateTime         @default(now())

  @@unique([workerId, challengeId])
  @@index([workerId])
}

model Squad {
  id                    String   @id @default(cuid())
  name                  String
  description           String?
  sharedReputationScore Float    @default(100)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  members SquadMembership[]
  bids    SquadBid[]
}

model SquadMembership {
  id       String    @id @default(cuid())
  squadId  String
  userId   String
  role     SquadRole @default(MEMBER)
  squad    Squad     @relation(fields: [squadId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime  @default(now())

  @@unique([squadId, userId])
  @@index([userId])
}

model SquadBid {
  id        String         @id @default(cuid())
  squadId   String
  jobId     String
  squad     Squad          @relation(fields: [squadId], references: [id], onDelete: Cascade)
  job       JobRequirement @relation(fields: [jobId], references: [id], onDelete: Cascade)
  message   String?
  createdAt DateTime       @default(now())

  @@unique([squadId, jobId])
}

model JobRequirement {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  description  String
  skills       String[]
  budget          String?
  budgetMin       Int?
  budgetMax       Int?
  category                String?
  collarType              CollarType       @default(WHITE)
  paymentType             RateType         @default(FIXED)
  experienceLevel         ExperienceLevel  @default(INTERMEDIATE)
  weeklyHours             JobWeeklyHours   @default(TBD)
  durationType            ProjectDuration?
  projectType             ProjectType      @default(ONE_TIME)
  niceToHaveSkills        String[]
  preferredQualifications String?
  freelancersNeeded       Int              @default(1)
  lastViewedByClientAt    DateTime?
  isSynthetic             Boolean          @default(false)
  timeline                String?
  geofenceRing            GeofenceRing     @default(CLOUD)
  lat          Float?
  lng          Float?
  isAiScoped   Boolean      @default(false)
  aiTiers      Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  connections        MatchmakingConnection[]
  standbyAssignments StandbyAssignment[]
  squadBids          SquadBid[]
  applications       JobApplication[]

  @@index([userId])
  @@index([geofenceRing])
}

model MatchmakingConnection {
  id                 String           @id @default(cuid())
  workerId           String
  jobId              String
  worker             WorkerProfile    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  job                JobRequirement   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  isAnonymous        Boolean          @default(true)
  identityRevealedAt DateTime?
  introducedAt       DateTime?
  introducedById     String?
  introducedBy       User?            @relation("IntroducedBy", fields: [introducedById], references: [id])
  connectionStatus   ConnectionStatus @default(PENDING_CONTACT)
  contractStartDate  DateTime?
  createdAt          DateTime         @default(now())

  milestones   Milestone[]
  review       Review?
  messages     Message[]
  submissions  WorkSubmission[]
  subJobs      SubJob[]
  serviceOrder ServiceOrder?

  @@unique([workerId, jobId])
  @@index([workerId])
  @@index([jobId])
  @@index([introducedAt])
  @@index([connectionStatus])
}

model Milestone {
  id                String                @id @default(cuid())
  connectionId      String
  connection        MatchmakingConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  title             String
  description       String?
  amount            Int
  status            MilestoneStatus       @default(PENDING)
  clientConfirmedAt DateTime?
  workerConfirmedAt DateTime?
  dueDate           DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  commissionEntry CommissionLedger?

  @@index([connectionId])
  @@index([status])
}

model CommissionLedger {
  id          String    @id @default(cuid())
  milestoneId String    @unique
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  grossAmount Int
  platformFee Int
  isPaid      Boolean   @default(false)
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
}

model StandbyAssignment {
  id        String         @id @default(cuid())
  jobId     String
  workerId  String
  job       JobRequirement @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker    WorkerProfile  @relation(fields: [workerId], references: [id], onDelete: Cascade)
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())

  @@unique([jobId, workerId])
  @@index([jobId])
}

model MerchantOffer {
  id              String   @id @default(cuid())
  merchantName    String
  category        String   @default("Food & Drink")
  description     String
  discountPercent Int
  address         String
  lat             Float    @default(9.9312)
  lng             Float    @default(76.2673)
  qrCode          String   @unique @default(cuid())
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  redemptions MerchantRedemption[]
}

model MerchantRedemption {
  id         String        @id @default(cuid())
  offerId    String
  workerId   String
  offer      MerchantOffer @relation(fields: [offerId], references: [id])
  redeemedAt DateTime      @default(now())

  @@index([offerId])
  @@index([workerId])
}

model Review {
  id           String                @id @default(cuid())
  connectionId String                @unique
  workerId     String
  clientId     String
  connection   MatchmakingConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  worker       WorkerProfile         @relation(fields: [workerId], references: [id], onDelete: Cascade)
  rating       Int
  qualityRating         Int?
  communicationRating   Int?
  professionalismRating Int?
  reliabilityRating     Int?
  flexibilityRating     Int?
  comment      String?
  createdAt    DateTime              @default(now())

  @@index([workerId])
  @@index([clientId])
}

model JobApplication {
  id                String               @id @default(cuid())
  jobId             String
  workerId          String
  coverLetter       String?
  rateType          RateType             @default(FIXED)
  proposedRate      Int?
  estimatedDays     Int?
  availabilityHours Int?
  status            JobApplicationStatus @default(PENDING)
  appliedAt         DateTime             @default(now())

  job         JobRequirement     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker      WorkerProfile      @relation(fields: [workerId], references: [id], onDelete: Cascade)
  attachments PortfolioProject[] @relation("ApplicationAttachments")

  @@unique([jobId, workerId])
  @@index([jobId])
  @@index([workerId])
}

model PortfolioProject {
  id          String   @id @default(cuid())
  workerId    String
  worker      WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  title       String
  description String
  imageUrl    String?
  projectUrl  String?
  role        String?
  skills      String[]
  createdAt   DateTime @default(now())

  applications JobApplication[] @relation("ApplicationAttachments")

  @@index([workerId])
}

model EmploymentHistory {
  id          String        @id @default(cuid())
  workerId    String
  worker      WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  title       String
  company     String
  startDate   DateTime
  endDate     DateTime?
  isCurrent   Boolean       @default(false)
  description String?
  createdAt   DateTime      @default(now())

  @@index([workerId])
}

model Education {
  id           String        @id @default(cuid())
  workerId     String
  worker       WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  institution  String
  degree       String?
  fieldOfStudy String?
  startYear    Int?
  endYear      Int?
  createdAt    DateTime      @default(now())

  @@index([workerId])
}

model Certification {
  id            String        @id @default(cuid())
  workerId      String
  worker        WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  name          String
  provider      String
  issueYear     Int?
  credentialUrl String?
  createdAt     DateTime      @default(now())

  @@index([workerId])
}

model WorkerLanguage {
  id          String              @id @default(cuid())
  workerId    String
  worker      WorkerProfile       @relation(fields: [workerId], references: [id], onDelete: Cascade)
  name        String
  proficiency LanguageProficiency @default(CONVERSATIONAL)

  @@unique([workerId, name])
  @@index([workerId])
}

model Message {
  id           String                @id @default(cuid())
  connectionId String
  senderId     String
  content      String
  createdAt    DateTime              @default(now())

  connection MatchmakingConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  sender     User                  @relation("SentMessages", fields: [senderId], references: [id])

  @@index([connectionId])
  @@index([createdAt])
}

model WorkSubmission {
  id           String                @id @default(cuid())
  connectionId String
  workerId     String
  title        String
  description  String?
  fileUrl      String?
  isPreview    Boolean               @default(false)
  isApproved   Boolean               @default(false)
  createdAt    DateTime              @default(now())

  connection MatchmakingConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  worker     WorkerProfile         @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([connectionId])
}

model SubJob {
  id                 String                @id @default(cuid())
  parentConnectionId String
  postedById         String
  title              String
  description        String
  skills             String[]
  budget             String?
  isPublic           Boolean               @default(false)
  createdAt          DateTime              @default(now())

  parentConnection MatchmakingConnection @relation(fields: [parentConnectionId], references: [id], onDelete: Cascade)
  postedBy         WorkerProfile         @relation("PostedSubJobs", fields: [postedById], references: [id], onDelete: Cascade)
  applications     SubJobApplication[]

  @@index([postedById])
  @@index([parentConnectionId])
}

model SubJobApplication {
  id          String               @id @default(cuid())
  subJobId    String
  workerId    String
  coverLetter String?
  status      JobApplicationStatus @default(PENDING)
  appliedAt   DateTime             @default(now())

  subJob SubJob        @relation(fields: [subJobId], references: [id], onDelete: Cascade)
  worker WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([subJobId, workerId])
  @@index([subJobId])
  @@index([workerId])
}

model ServicePackage {
  id            String        @id @default(cuid())
  workerId      String
  worker        WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  title         String
  description   String
  category      String
  skills        String[]
  coverImageUrl String?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tiers  ServiceTier[]
  orders ServiceOrder[]

  @@index([workerId])
  @@index([category])
  @@index([isActive])
}

model ServiceTier {
  id           String          @id @default(cuid())
  packageId    String
  package      ServicePackage  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  name         ServiceTierName
  price        Int
  deliveryDays Int
  revisions    Int             @default(1)
  description  String?
  features     String[]

  orders ServiceOrder[]

  @@unique([packageId, name])
}

model ServiceOrder {
  id           String             @id @default(cuid())
  packageId    String
  tierId       String
  clientId     String
  workerId     String
  status       ServiceOrderStatus @default(PENDING)
  fastTrack    Boolean            @default(false)
  fastTrackFee Int                @default(0)
  requirements String?
  connectionId String?            @unique
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  package    ServicePackage         @relation(fields: [packageId], references: [id], onDelete: Cascade)
  tier       ServiceTier            @relation(fields: [tierId], references: [id])
  client     User                   @relation("ClientOrders", fields: [clientId], references: [id], onDelete: Cascade)
  worker     WorkerProfile          @relation("WorkerOrders", fields: [workerId], references: [id], onDelete: Cascade)
  connection MatchmakingConnection? @relation(fields: [connectionId], references: [id])

  @@index([clientId])
  @@index([workerId])
  @@index([status])
}
